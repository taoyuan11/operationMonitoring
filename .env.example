# Required by both Compose variants: replace these passwords before deployment.
# The with-db file initializes PostgreSQL with OM_DATABASE_PASSWORD; the external file
# uses the same variable to authenticate to OM_DATABASE_URL.
OM_DATABASE_PASSWORD=replace-with-database-password
OM_ADMIN_PASSWORD=replace-with-a-long-random-bootstrap-password

# Defaults for the PostgreSQL container created by docker-compose.with-db.yml.
POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_DB=operation_monitoring
POSTGRES_USER=operation_monitoring

# Required by docker-compose.yml when connecting to an external PostgreSQL.
# The database host must be reachable from the backend container; do not use 127.0.0.1.
OM_DATABASE_URL=postgresql://operation_monitoring@db.example.com:5432/operation_monitoring?sslmode=require

# Host ports. An IP-prefixed value such as 127.0.0.1:13500 binds only to loopback.
FRONTEND_PORT=13501
BACKEND_PORT=13500

# Set to true only when users access the service through HTTPS.
OM_SECURE_COOKIES=false

# Upload and transfer limits must not exceed the Nginx request-body limit.
OM_AGENT_PACKAGE_MAX_BYTES=268435456
OM_FILE_TRANSFER_MAX_BYTES=1073741824
NGINX_CLIENT_MAX_BODY_SIZE=1g

RUST_LOG=backend=info,tower_http=info
